# Cloudflare Pages custom headers
# Prevent aggressive browser/CDN caching of HTML so fixes go live immediately

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate

/about.html
  Cache-Control: no-cache, no-store, must-revalidate

/privacy.html
  Cache-Control: no-cache, no-store, must-revalidate

/terms.html
  Cache-Control: no-cache, no-store, must-revalidate
